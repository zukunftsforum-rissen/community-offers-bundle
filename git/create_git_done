git config --global alias.done '!bash -c '"'"'
if ! git diff --quiet || ! git diff --cached --quiet; then
  echo "❌ Uncommitted changes detected."
  echo "Please commit or stash them before running git done."
  exit 1
fi

git switch main >/dev/null 2>&1 || exit 1
git fetch --prune origin &&
git reset --hard origin/main || exit 1

for b in $(git for-each-ref --format="%(refname:short)" refs/heads/ | grep -v "^main$"); do
  if git diff --quiet main "$b"; then
    git branch -D "$b"
  fi
done

echo "✔ main synced with origin/main"
echo "✔ local branches identical to main removed"
'"'"