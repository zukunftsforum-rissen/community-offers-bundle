<!doctype html>
<html lang="de">
	<head>
		<meta charset="utf-8">
		<meta name="viewport" content="width=device-width, initial-scale=1">
		<title>{{ title }}</title>

		<meta name="theme-color" content="#2d6cdf">
		<meta name="apple-mobile-web-app-capable" content="yes">
		<meta name="apple-mobile-web-app-title" content="Zugänge">

		{% block community_offers_manifest %}
			<link rel="manifest" href="{{ asset('bundles/communityoffers/app/manifest.webmanifest') }}">
		{% endblock %}

		{% block community_offers_icons %}
			<link rel="apple-touch-icon" href="{{ asset('bundles/communityoffers/app/icons/icon-192.png') }}">
		{% endblock %}

		{% block community_offers_styles %}
			<link rel="stylesheet" href="{{ asset('bundles/communityoffers/app/base.css') }}">
		{% endblock %}
	</head>
	<body>
		<main class="wrap">
			<h1>Zugänge</h1>

			<p>Zur Zeit ist dies eine reine Emulation der Türöffner-Hardware. Es werden keine echten Türen geöffnet.</p>

			<p id="status" class="status">Lade …</p>

			<section id="actions" class="hidden"></section>

			<section id="loginHint" class="hidden">

				<a class="btn login-main" id="loginLink" href="{{ appConfig.loginPath }}">
					🔐 Bitte einloggen
				</a>

				<a class="request-link-login" href="/zugang-anfragen">
					Noch kein Zugang? → Zugang anfragen
				</a>

			</section>

			<footer class="app-legal">
				<p>
					Mit der Nutzung dieser Anwendung gelten die
					<a href="/community-regeln" target="_blank" rel="noopener noreferrer">Regeln unserer Community</a>.
																																														    Türöffnungen werden zu Sicherheits- und Betriebszwecken protokolliert.
					<a href="/datenschutz" target="_blank" rel="noopener noreferrer">Datenschutzerklärung</a>
				</p>
			</footer>

		</main>

		<script>
			window.CO_APP_CONFIG = {{ appConfig|json_encode(constant('JSON_UNESCAPED_SLASHES'))|raw }};
		</script>
		<script type="module" src="{{ asset('bundles/communityoffers/app/app.js') }}"></script>
	</body>
</html>
