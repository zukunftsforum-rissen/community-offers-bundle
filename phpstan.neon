includes:
    - %currentWorkingDirectory%/vendor/phpstan/phpstan-symfony/extension.neon
    - %currentWorkingDirectory%/vendor/phpstan/phpstan-symfony/rules.neon

parameters:
    level: 6

    paths:
        - src

    # Contao models/templates are dynamic (optional – falls ihr diese nutzt)
    universalObjectCratesClasses:
        - Contao\Model
        - Contao\Template

    # Wenn ignoreErrors mal nicht matcht, soll es nicht hard failen
    reportUnmatchedIgnoredErrors: false

    excludePaths:
        - src/Resources/*

    ignoreErrors:
        -
            message: '#Call to method booleanNode\(\) on an unknown class Symfony\\Component\\Config\\Definition\\Builder\\NodeBuilder#'
            path: src/DependencyInjection/Configuration.php
            # Symfony Config Builder fluent API is runtime-correct here, but PHPStan
            # cannot resolve the generic NodeBuilder type for booleanNode().