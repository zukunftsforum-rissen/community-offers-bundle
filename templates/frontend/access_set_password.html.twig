{% extends "@CommunityOffers/layout/public.tool.html.twig" %}

{% set title = 'Passwort vergeben' %}

{% block head %}
<style>
    .co-password-setup {
        max-width: 32rem;
    }

    .co-password-setup h1 {
        margin-top: 0;
        margin-bottom: 1rem;
        font-size: 2.4rem;
        line-height: 1.1;
    }

    .co-password-setup p {
        margin-bottom: 1rem;
    }

    .co-password-setup .form-row {
        margin-bottom: 1rem;
    }

    .co-password-setup label {
        display: block;
        margin-bottom: 0.35rem;
        font-weight: 600;
    }

    .co-password-setup input[type="password"] {
        width: 100%;
        max-width: 22rem;
        padding: 0.55rem 0.65rem;
        font: inherit;
        box-sizing: border-box;
    }

    .co-password-setup button {
        padding: 0.6rem 1rem;
        font: inherit;
        cursor: pointer;
    }

    .alert-danger {
        margin-bottom: 1rem;
        padding: 0.75rem 1rem;
        border: 1px solid #d8a1a1;
        background: #fce8e8;
    }
</style>
{% endblock %}

{% block main %}
<div class="co-password-setup">
    <h1>Passwort vergeben</h1>

    {% if success %}
        <p>Dein Passwort wurde gespeichert.</p>
        <p>Dein Zugang wird nach Freigabe durch das Team aktiviert.</p>
    {% else %}
        <p>Bitte vergib jetzt dein Passwort.</p>

        {% if errors %}
            <div class="alert-danger">
                <ul>
                    {% for error in errors %}
                        <li>{{ error }}</li>
                    {% endfor %}
                </ul>
            </div>
        {% endif %}

        <form method="post">
            <input type="hidden" name="REQUEST_TOKEN" value="{{ request_token }}">

            <div class="form-row">
                <label for="password">Passwort</label>
                <input
                    type="password"
                    id="password"
                    name="password"
                    required
                    autocomplete="new-password"
                >
            </div>

            <div class="form-row">
                <label for="password_confirm">Passwort wiederholen</label>
                <input
                    type="password"
                    id="password_confirm"
                    name="password_confirm"
                    required
                    autocomplete="new-password"
                >
            </div>

            <button type="submit">Passwort speichern</button>
        </form>
    {% endif %}
</div>
{% endblock %}
