{% trans_default_domain 'contao_default' %}
{% extends "@Contao/mod_login.html.twig" %}

{#
    Dieses Template erweitert das Standard-Login-Template
    und überschreibt nur den Username-Block.
#}

{% block content %}

	{% set prefilledUsername = app.request.query.get('username')|default('') %}
	{% set loginIdentifier = login_identifier|default('email') %}

	<form {% if action|default %} action="{{ action }}" {% endif %} id="{{ formId }}" method="post">

		<div class="formbody">

			{% if message|default %}
				<p class="error">{{ message }}</p>
			{% endif %}

			<input type="hidden" name="FORM_SUBMIT" value="{{ formId }}">
			<input type="hidden" name="REQUEST_TOKEN" value="{{ contao.request_token }}">
			<input type="hidden" name="_target_path" value="{{ targetPath }}">
			<input type="hidden" name="_always_use_target_path" value="{{ forceTargetPath|default }}">

			{% if remembered|default %}
				<input type="hidden" name="username" value="{{ value }}">
				<input type="hidden" name="autologin" value="{{ autologin|default ? '1' : '' }}">
			{% elseif logout|default %}

				<p class="login_info">
					{{ loggedInAs }}<br>
					{{ lastLogin|default }}
				</p>

			{% elseif twoFactorEnabled|default %}

				{{ parent() }}

			{% else %}

				{% if remembered|default %}

					<p class="login_info">
						{{ loggedInAs }}<br>
						{{ reauthenticate }}
					</p>

				{% else %}

					{# ===== HIER DIE ANPASSUNG ===== #}

					<div class="widget widget-text">

						<label for="username">
							{% if loginIdentifier == 'email' %}
								Email-Adresse
							{% else %}
								{{ username }}
							{% endif %}
						</label>

						<input type="text" name="username" id="username" class="text" value="{{ prefilledUsername ?: value }}" autocapitalize="off" autocomplete="username" required>

					</div>

				{% endif %}

				<div class="widget widget-password">
					<label for="password">{{ password }}</label>
					<input type="password" name="password" id="password" class="text password" value="" autocomplete="current-password" required>
				</div>

				{% if autologin and not remembered|default %}
					<div class="widget widget-checkbox">
						<fieldset class="checkbox_container">
							<span>
								<input type="checkbox" name="autologin" id="autologin" value="1" class="checkbox">
								<label for="autologin">
									{{ autoLabel }}
								</label>
							</span>
						</fieldset>
					</div>
				{% endif %}

			{% endif %}

			<div class="widget widget-submit">
				<button type="submit" class="submit">
					{{ slabel }}
				</button>

				{% if twoFactorEnabled|default %}
					<a href="{{ path('contao_frontend_logout') }}">
						{{ cancel }}
						›
					</a>
				{% endif %}
			</div>

			{% if pwResetUrl|default %}
				<div class="password-reset">
					<a href="{{ pwResetUrl }}">
						{{ 'MSC.lostPassword'|trans }}
					</a>
				</div>
			{% endif %}

		</div>

	</form>

{% endblock %}
