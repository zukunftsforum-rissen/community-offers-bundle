includes:
    - vendor/phpstan/phpstan-symfony/extension.neon
    - vendor/phpstan/phpstan-symfony/rules.neon

parameters:
    level: 6

    paths:
        - src

    # Contao models/templates are dynamic (optional – falls ihr diese nutzt)
    universalObjectCratesClasses:
        - Contao\Model
        - Contao\Template

    # Wenn ignoreErrors mal nicht matcht, soll es nicht hard failen
    reportUnmatchedIgnoredErrors: false

    excludePaths:
        - src/Resources/*