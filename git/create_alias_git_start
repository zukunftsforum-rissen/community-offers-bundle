git config --global alias.start '!bash -c '"'"'
current=$(git rev-parse --abbrev-ref HEAD 2>/dev/null) || exit 1

types=(fix feat docs refactor test chore)

echo "Select branch type:"
select type in "${types[@]}"; do
  [ -n "$type" ] && break
done

read -p "Branch name: " name
name=${name// /-}
branch="$type/$name"

if ! git diff --quiet || ! git diff --cached --quiet; then
  echo "Uncommitted changes detected."
  echo "Creating branch from current state without resetting anything..."
  git switch -c "$branch" &&
  echo "✔ Created branch $branch with your current changes"
  exit $?
fi

git switch main >/dev/null 2>&1 || exit 1
git fetch origin &&
git reset --hard origin/main &&
git switch -c "$branch" &&
echo "✔ Created clean branch $branch from origin/main"
'"'"
