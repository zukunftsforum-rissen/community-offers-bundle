includes:
    - phpstan.neon

parameters:
    paths:
        - tests

    # etwas lockerer für Tests
    level: 5

    # reduziert “always true/false” und Array-shape Noise in Tests
    treatPhpDocTypesAsCertain: false

    # typische Test-Noise-Checks etwas entspannen
    checkMissingIterableValueType: false
    checkGenericClassInNonGenericObjectType: false

    reportUnmatchedIgnoredErrors: false

    ignoreErrors:
        # PHPUnit / Fixture-Noise (sehr typisch)
        - '#Call to method PHPUnit\\\\Framework\\\\Assert::assert.* will always evaluate to false#'
        - '#Offset .* does not exist on array#'